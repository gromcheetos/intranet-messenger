# ══════════════════════════════════════════════════════════════
# Local Development — Oracle (default)
# ══════════════════════════════════════════════════════════════
SPRING_PROFILES_ACTIVE=dev

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=jdbc:oracle:thin:@localhost:1523/XE
DATABASE_USERNAME=system
DATABASE_PASSWORD=system123

# ── Server ────────────────────────────────────────────────────
SERVER_PORT=8085
SERVER_CONTEXT_PATH=/hk

# ── Frontend ──────────────────────────────────────────────────
VITE_API_URL=https://intranet-messenger-production.up.railway.app/hk


# ══════════════════════════════════════════════════════════════
# Local Test — PostgreSQL (uncomment to test before deploying)
# Run: docker-compose --profile postgres up
# ══════════════════════════════════════════════════════════════
# SPRING_PROFILES_ACTIVE=prod
# DATABASE_URL=jdbc:postgresql://localhost:5432/messenger
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=postgres123
# SERVER_PORT=8085
# SERVER_CONTEXT_PATH=/hk
# VITE_API_URL=http://localhost:8085/hk


# ══════════════════════════════════════════════════════════════
# Production — Railway + Supabase
# Set these in Railway dashboard, NOT here
# ══════════════════════════════════════════════════════════════
# SPRING_PROFILES_ACTIVE=prod
# DATABASE_URL=jdbc:postgresql://db.[ref].supabase.co:5432/postgres
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=your-supabase-password
# SERVER_PORT=8085
# SERVER_CONTEXT_PATH=/hk
